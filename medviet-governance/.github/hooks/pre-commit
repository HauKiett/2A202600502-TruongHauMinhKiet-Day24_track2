#!/bin/sh
# Pre-commit hook: chạy security checks trước khi commit
# Hoạt động trên Linux/Mac (bash) — Windows dùng .github/hooks/pre-commit.py

echo "Running security checks..."

# 1. git-secrets scan (nếu cài)
if command -v git-secrets >/dev/null 2>&1; then
    git secrets --pre_commit_hook -- "$@"
    if [ $? -ne 0 ]; then
        echo "git-secrets found potential secrets! Commit blocked."
        exit 1
    fi
fi

# 2. Bandit SAST scan
echo "Running Bandit SAST..."
bandit -r src/ -ll -q
if [ $? -ne 0 ]; then
    echo "Bandit found security issues! Review above."
    exit 1
fi

# 3. Custom secret pattern scan (fallback cho khi không có git-secrets)
python .github/hooks/pre-commit.py
if [ $? -ne 0 ]; then
    echo "Custom secret scan found issues! Commit blocked."
    exit 1
fi

echo "All security checks passed!"
exit 0
